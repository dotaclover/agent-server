# Go Agent Studio — 环境变量配置
# 复制为 .env 后填入实际值：copy .env.example .env
#
# 本文件只保留当前业务路径推荐配置的变量。
# 完整读取逻辑以 config/config.go 为准。

# ============================================================
# 应用
# ============================================================
APP_NAME=Go Agent Studio
APP_HOST=127.0.0.1
APP_PORT=9090
APP_DEBUG=true
APP_ACCESS_LOG_ENABLED=true
APP_DB_PATH=data/agent_studio.db

# HTTP 超时
APP_READ_TIMEOUT=30s
APP_WRITE_TIMEOUT=0
APP_IDLE_TIMEOUT=60s
APP_SHUTDOWN_TIMEOUT=20s

# 全局速率限制
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_RPS=20
APP_RATE_LIMIT_BURST=60

# HTTP 安全
APP_BODY_LIMIT=2M
APP_CORS_ALLOWED_ORIGINS=http://127.0.0.1:9090,http://localhost:9090
APP_SECURE_HEADERS_ENABLED=true
APP_HSTS_MAX_AGE=31536000

# ============================================================
# 聊天 LLM（DeepSeek）
# ============================================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_TEMPERATURE=0.5
AI_MAX_TOKENS=2048
AI_REQUEST_TIMEOUT=180s

# ============================================================
# MCP Client
# ============================================================
MCP_ENABLED=true
MCP_CONFIG_PATH=mcp.json

# ============================================================
# Agent 核心配置
# ============================================================
AGENT_MAX_MESSAGE_CHARS=4000
AGENT_CHAT_TIMEOUT=10m
AGENT_TOOL_TIMEOUT=30s
AGENT_PLANNER_TIMEOUT=5s
AGENT_AUTO_CONFIRM_MCP=true

# ============================================================
# Customer 端配置（Dify 产品文档问答）
# ============================================================
CUSTOMER_MAX_TURNS=10
CUSTOMER_MAX_DAILY_VISITORS=1000
CUSTOMER_RAG_API_ENDPOINT=http://localhost:9093/api/search

# ============================================================
# Operator 端配置（写作助手）
# ============================================================
# 不配置 AGENT_OPERATOR_API_KEY 时，Operator API 不注册。
OPERATOR_MAX_TURNS=30
AGENT_OPERATOR_API_KEY=

# ============================================================
# Admin 端配置（管理控制台）
# ============================================================
# 不配置 AGENT_ADMIN_API_KEY 时，Admin API 不注册。
ADMIN_SESSION_RETENTION_DAYS=90
AGENT_ADMIN_API_KEY=
AGENT_AUDIT_LOG_ENABLED=true
