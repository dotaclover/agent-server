# 最小化配置 — DeepSeek
# 用法: copy .env.simple .env
#
# 当前仓库只直接使用聊天 LLM。Customer 的产品文档检索通过外部
# CUSTOMER_RAG_API_ENDPOINT 调用独立 RAG HTTP 服务。

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# 外部 RAG 服务（需独立启动）
CUSTOMER_RAG_API_ENDPOINT=http://localhost:9093/api/search

# 示例 MCP Server 默认不连接；如需使用，请先启动 mcp.json 中的服务。
MCP_ENABLED=false
